# ============================================
# CleanMateX - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# Environment
# ============================================
NODE_ENV=development

# ============================================
# Database (Direct PostgreSQL Connection)
# ============================================
# For Prisma ORM - Direct PostgreSQL connection
#
# ⚠️ IMPORTANT: We use Supabase's PostgreSQL (port 54322), NOT Docker postgres
# Local development (Supabase Local - use your host IP if not localhost):
# connection_limit: avoid "Timed out fetching a new connection from the connection pool"
# options=-c statement_timeout=60000: avoid "canceling statement due to statement timeout" (60s)
DATABASE_URL=postgresql://postgres:postgres@192.168.100.24:54322/postgres?connection_limit=10&pool_timeout=20&options=-c%20statement_timeout%3D60000

# Production (Supabase Cloud with connection pooling):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20&options=-c%20statement_timeout%3D60000

DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

