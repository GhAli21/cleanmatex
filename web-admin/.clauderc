# Web Admin Dashboard - Claude Code Configuration
# Location: web-admin/.clauderc

context: "Next.js Admin Dashboard for CleanMateX Laundry SaaS"

# Important Files
important_files:
  - "app/[locale]/layout.tsx"           # Root layout
  - "lib/api/client.ts"                 # API client
  - "src/ui/*"                         # UI design system (@ui)
  - "messages/*.json"                   # i18n translations
  - "middleware.ts"                     # Next.js middleware
  - "next.config.js"                    # Next.js configuration

# Component Structure
component_structure:
  - "Use React Server Components by default"
  - "Add 'use client' only when needed (interactivity, hooks)"
  - "Separate components into ui/, forms/, layouts/"
  - "Use TypeScript interfaces for props"
  - "Export named components, not default"

# Page Structure (App Router)
page_structure:
  layout: "layout.tsx"                  # Shared layout
  page: "page.tsx"                      # Page component
  loading: "loading.tsx"                # Loading state
  error: "error.tsx"                    # Error boundary
  not-found: "not-found.tsx"            # 404 page

# Styling Rules
styling:
  framework: "TailwindCSS"
  approach: "Mobile-first responsive design"
  rtl: "Support RTL with dir='rtl' for Arabic"
  utilities: "Use Tailwind utility classes"
  custom: "Use CSS variables for theming"
  examples:
    - "flex items-center justify-between"
    - "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3"
    - "p-4 md:p-6 lg:p-8"
    - "text-right rtl:text-left"

# i18n (Internationalization)
i18n:
  library: "next-intl"
  languages: ["en", "ar"]
  usage: |
    import { useTranslations } from 'next-intl';
    const t = useTranslations('orders');
    <h1>{t('title')}</h1>
  files: "messages/en.json, messages/ar.json"
  rules:
    - "All user-facing text must use translation keys"
    - "Test RTL layout for Arabic"
    - "Use semantic keys: 'orders.create.title' not 'label1'"

# API Integration
api:
  client: "axios or fetch in lib/api/client.ts"
  state: "React Query (TanStack Query)"
  patterns: |
    // Using React Query
    const { data, isLoading, error } = useQuery({
      queryKey: ['orders', filters],
      queryFn: () => api.getOrders(filters)
    });
    
    const mutation = useMutation({
      mutationFn: api.createOrder,
      onSuccess: () => queryClient.invalidateQueries(['orders'])
    });

# Forms
forms:
  library: "react-hook-form"
  validation: "zod"
  example: |
    import { useForm } from 'react-hook-form';
    import { zodResolver } from '@hookform/resolvers/zod';
    import * as z from 'zod';
    
    const schema = z.object({
      customerName: z.string().min(1),
      phone: z.string().min(10)
    });
    
    const form = useForm({
      resolver: zodResolver(schema)
    });

# State Management
state:
  server: "React Query (for API data)"
  local: "useState/useReducer"
  global: "Zustand (minimal usage)"
  url: "useSearchParams (for filters)"

# Development Commands
commands:
  dev: "npm run dev"
  build: "npm run build"
  start: "npm run start"
  lint: "npm run lint"
  test: "npm run test"

# Component Templates — always use Cmx components, never raw HTML elements
templates:
  page_component: |
    import { CmxCrudPageShell } from '@ui/patterns';
    import { CmxDataTable } from '@ui/data-display';
    import { CmxEmptyState } from '@ui/data-display';

    export default function OrdersPage() {
      return (
        <CmxCrudPageShell>
          <CmxDataTable columns={[]} data={[]} emptyState={<CmxEmptyState />} />
        </CmxCrudPageShell>
      );
    }

  client_component: |
    'use client';

    import { CmxForm, CmxFormField, CmxFormSection, CmxFormActions } from '@ui/forms';
    import { CmxInput } from '@ui/primitives';
    import { CmxButton } from '@ui/primitives';

    export function OrderForm() {
      return (
        <CmxForm layout="stacked">
          <CmxFormSection>
            <CmxFormField label="Name">
              <CmxInput />
            </CmxFormField>
          </CmxFormSection>
          <CmxFormActions>
            <CmxButton type="submit">Submit</CmxButton>
          </CmxFormActions>
        </CmxForm>
      );
    }

# UI Components (@ui design system - Cmx components)
# Keep in sync with web-admin/src/ui. Used by AI for import suggestions.
# RULE: Use Cmx components ONLY. Do NOT use @ui/compat (removed), @/components/ui, or raw HTML elements.
# See docs/dev/ui-migration-guide.md and docs/dev/compat-to-cmx-migration-notes.md
ui_components:
  # ── Primitives ──────────────────────────────────────────────────
  button: "import { CmxButton } from '@ui/primitives'"
  loading_button: "import { LoadingButton } from '@ui/primitives'"
  input: "import { CmxInput } from '@ui/primitives'"
  money_field: "import { CmxMoneyField } from '@ui/primitives'"
  money_field_controller: "import { CmxMoneyFieldController } from '@ui/primitives'"
  textarea: "import { CmxTextarea } from '@ui/primitives'"
  select: "import { CmxSelect } from '@ui/primitives'"
  checkbox: "import { CmxCheckbox } from '@ui/primitives'"
  switch: "import { CmxSwitch } from '@ui/primitives'"
  skeleton: "import { CmxSkeleton, CmxSkeletonTable } from '@ui/primitives'"
  spinner: "import { CmxSpinner } from '@ui/primitives'"
  label: "import { Label } from '@ui/primitives'"
  badge: "import { Badge } from '@ui/primitives/badge'"
  alert: "import { Alert, AlertDescription } from '@ui/primitives'"
  separator: "import { Separator } from '@ui/primitives'"
  tooltip: "import { Tooltip } from '@ui/primitives'"
  card: "import { CmxCard, CmxCardHeader, CmxCardTitle, CmxCardContent, CmxCardFooter } from '@ui/primitives/cmx-card'"
  # ── Forms ────────────────────────────────────────────────────────
  form: "import { CmxForm, CmxFormField, CmxFormSection, CmxFormActions, CmxFormSkeleton, CmxFormStatusBanner } from '@ui/forms'"
  field_shell: "import { CmxFieldShell } from '@ui/forms'"
  select_dropdown: "import { CmxSelectDropdown, CmxSelectDropdownTrigger, CmxSelectDropdownValue, CmxSelectDropdownContent, CmxSelectDropdownItem } from '@ui/forms'"
  checkbox_group: "import { CmxCheckboxGroup } from '@ui/forms'"
  hex_color_field: "import { CmxHexColorField } from '@ui/forms'"
  # ── Overlays ─────────────────────────────────────────────────────
  dialog: "import { CmxDialog, CmxDialogContent, CmxDialogHeader, CmxDialogTitle, CmxDialogFooter } from '@ui/overlays'"
  # ── Feedback ─────────────────────────────────────────────────────
  progress: "import { CmxProgressBar } from '@ui/feedback'"
  progress_indicator: "import { CmxProgressIndicator } from '@ui/feedback'"
  summary_message: "import { CmxSummaryMessage } from '@ui/feedback'"
  status_badge: "import { CmxStatusBadge } from '@ui/feedback'"
  confirm_dialog: "import { CmxConfirmDialog } from '@ui/feedback'"
  # ── Data Display ─────────────────────────────────────────────────
  data_table: "import { CmxDataTable } from '@ui/data-display'"
  empty_state: "import { CmxEmptyState } from '@ui/data-display'"
  kpi_stat_card: "import { CmxKpiStatCard } from '@ui/data-display'"
  # ── Navigation ───────────────────────────────────────────────────
  tabs: "import { CmxTabsPanel } from '@ui/navigation'"
  pagination: "import { CmxPagination } from '@ui/navigation'"
  progress_steps: "import { CmxProgressSteps } from '@ui/navigation'"
  # ── Page-level Patterns ──────────────────────────────────────────
  crud_page_shell: "import { CmxCrudPageShell } from '@ui/patterns'"
  money_keypad: "import { CmxMoneyKeypad } from '@ui/utilities'"
  keypad: "import { CmxKeypad } from '@ui/utilities'"
  keypad_presets: "import { KEYPAD_PAYMENT_4COL, KEYPAD_NUMERIC_3COL, PAYMENT_KEY_VARIANT, PAYMENT_KEY_CLASS } from '@ui/utilities'"
  card_with_header: "import { CmxCardWithHeader } from '@ui/patterns'"
  # ── Toast (imperative) ───────────────────────────────────────────
  toast: "import { showSuccessToast, showErrorToast, showInfoToast } from '@ui/components/cmx-toast'"

# React hooks & ESLint (portable — copy docs/dev/rules/*.md with this block)
react_hooks:
  checklist: "docs/dev/rules/react-lint-verification-checklist.md"
  effects_doc: "docs/dev/rules/react-effects-patterns.md"
  rhf_table_doc: "docs/dev/rules/react-rhf-and-table-lint.md"
  react_learn: "https://react.dev/learn"
  avoid_effects: "https://react.dev/learn/you-might-not-need-an-effect"
  verify: "cd web-admin && npx eslint . --quiet"
  rules:
    - "react-hooks/set-state-in-effect — reset UI during render when props change, not in useEffect"
    - "@next/next/no-html-link-for-pages — use Link from next/link for internal app routes"
    - "react-hooks/incompatible-library — use useWatch not form.watch; eslint-disable-next-line on useReactTable only"
    - "import/no-anonymous-default-export — named const before export default"
    - "jsx-a11y/role-supports-aria-props — combobox role when using aria-expanded on input"
    - "react-hooks/preserve-manual-memoization — include setState setters in useCallback deps"
    - "react-hooks/use-memo — dependency array must be literal (no spread)"

# Best Practices 
best_practices:
  - "Use TypeScript for all files"
  - "Implement loading and error states"
  - "Add proper error boundaries"
  - "Optimize images with next/image"
  - "Use dynamic imports for heavy components"
  - "Add meta tags for SEO"
  - "Test responsive design at all breakpoints"
  - "Ensure accessibility (ARIA labels)"

# Performance Optimization
performance:
  - "Use React.memo for expensive components"
  - "Implement virtualization for long lists"
  - "Use Next.js Image optimization"
  - "Add proper caching headers"
  - "Lazy load non-critical components"
  - "Debounce search inputs"

# Testing
testing:
  e2e: "Playwright"
  unit: "Jest + React Testing Library"
  example: |
    test('renders order list', async () => {
      render(<OrdersPage />);
      expect(screen.getByText('Orders')).toBeInTheDocument();
    });
