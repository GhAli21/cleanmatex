{
  "permissions": {
    "allow": [
      "Read(**/*.{ts,tsx,js,jsx,json,md,sql,yml,yaml,toml,sh,ps1,cmd,bat})",
      "Read(**/*.env.example)",
      "Read(docs/**)",
      "Read(scripts/**)",
      "Read(.claude/**)",
      "Read(supabase/migrations/**)",
      "Glob(**/*.{ts,tsx,js,jsx,json,md,sql})",
      "Grep(**)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm test*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run check:i18n*)",
      "Bash(cd*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ls*)",
      "Bash(dir*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(findstr*)",
      "Bash(wc*)",
      "Bash(node -e*)",
      "Bash(sed 's/\\(.*//')"
    ],
    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/.next/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/.git/**)",
      "Read(**/*.map)",
      "Read(**/*.min.js)",
      "Read(**/*.min.css)",
      "Bash(rm -rf /)",
      "Bash(rm -rf *)",
      "Bash(del /s /q C:\\*)",
      "Bash(del /s /q F:\\*)",
      "Bash(Remove-Item -Recurse -Force C:\\*)",
      "Bash(Remove-Item -Recurse -Force F:\\*)",
      "Bash(supabase db reset*)",
      "Bash(supabase db push*)",
      "Bash(supabase migration up*)",
      "Bash(npx supabase db reset*)",
      "Bash(npx supabase db push*)",
      "Bash(npx supabase migration up*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(sudo*)",
      "Bash(su -*)",
      "Bash(shutdown*)",
      "Bash(reboot*)"
    ],
    "ask": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git restore*)",
      "Bash(git reset*)",
      "Bash(git stash*)",
      "Bash(psql*)",
      "Bash(supabase*)",
      "Bash(npx supabase*)",
      "Bash(docker exec*)",
      "Bash(npm install*)",
      "Write(**/*.sql)",
      "Edit(**/*.sql)",
      "Write(supabase/migrations/**)",
      "Edit(supabase/migrations/**)",
      "Edit(CLAUDE.md)",
      "Edit(AGENTS.md)",
      "Edit(.claude/settings*.json)",
      "Bash(rm*)",
      "Bash(del*)",
      "Bash(Remove-Item*)"
    ]
  },
  "enabledMcpjsonServers": [
    "supabase_remote_with_token",
    "supabase_remote",
    "supabase_local",
    "supabase_remote_db"
  ],
  "outputStyle": "concise",
  "disabledMcpjsonServers": [
    "supabase"
  ]
}
